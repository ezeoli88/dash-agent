---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border-subtle py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <!-- Branding -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <div class="w-6 h-6 rounded-md bg-gradient-to-br from-accent-cyan to-accent-blue flex items-center justify-center">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
          </div>
          <span class="font-semibold text-sm text-text-primary">Agent Board</span>
        </div>
        <p class="text-xs text-text-muted">&copy; {currentYear} Agent Board. MIT License.</p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-3">Product</h4>
        <ul class="space-y-2">
          <li><a href="#features" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Features</a></li>
          <li><a href="#how-it-works" class="text-sm text-text-secondary hover:text-text-primary transition-colors">How it Works</a></li>
          <li><a href="https://www.npmjs.com/package/ai-agent-board" class="text-sm text-text-secondary hover:text-text-primary transition-colors">npm Package</a></li>
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-3">Links</h4>
        <ul class="space-y-2">
          <li><a href="https://github.com/ezeoli88/dash-agent" class="text-sm text-text-secondary hover:text-text-primary transition-colors">GitHub</a></li>
          <li><a href="https://github.com/ezeoli88/dash-agent/issues" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Report an Issue</a></li>
          <li><a href="https://github.com/ezeoli88/dash-agent/blob/main/LICENSE" class="text-sm text-text-secondary hover:text-text-primary transition-colors">License</a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>
