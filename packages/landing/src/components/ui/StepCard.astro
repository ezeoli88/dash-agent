---
interface Props {
  number: number;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div class="relative flex flex-col items-center text-center">
  <!-- Step number -->
  <div
    class="w-12 h-12 rounded-full flex items-center justify-center text-lg font-bold mb-4 bg-gradient-to-br from-accent-cyan to-accent-blue text-white shadow-lg shadow-accent-cyan/20"
  >
    {number}
  </div>
  <h3 class="text-lg font-semibold text-text-primary mb-2">{title}</h3>
  <p class="text-text-secondary text-sm leading-relaxed max-w-xs">{description}</p>
</div>
