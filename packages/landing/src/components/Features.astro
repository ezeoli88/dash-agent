---
import GlowCard from "./ui/GlowCard.astro";
import GradientText from "./ui/GradientText.astro";

const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><line x1="10" x2="8" y1="9" y2="9"/></svg>`,
    title: "Spec Generation",
    description: "Describe what you need in plain language. AI generates a detailed technical spec with acceptance criteria, ready for review.",
    accent: "var(--color-accent-cyan)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title: "Autonomous Coding",
    description: "Claude Code, Codex CLI, Gemini CLI, GitHub Copilot, or MiniMax work autonomously on your tasks — pick the agent that fits your workflow.",
    accent: "var(--color-accent-blue)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20v-6M6 20V10M18 20V4"/></svg>`,
    title: "Real-time Monitoring",
    description: "Live logs stream via SSE. Chat with the agent mid-task, send feedback, and watch tool calls as they happen.",
    accent: "var(--color-accent-purple)",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><path d="M11 18H8a2 2 0 0 1-2-2V9"/></svg>`,
    title: "PR Creation",
    description: "Review diffs side-by-side, leave comments, approve changes, and create pull requests — all without leaving the dashboard.",
    accent: "var(--color-accent-violet)",
  },
];
---

<section id="features" class="relative py-24 sm:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <span class="text-xs font-semibold uppercase tracking-widest text-accent-cyan mb-3 block">Features</span>
      <h2 class="text-3xl sm:text-4xl font-bold">
        Everything you need to <GradientText>ship with AI</GradientText>
      </h2>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {features.map((feature, i) => (
        <div data-animate data-animate-delay={String(i + 1)}>
          <GlowCard accentColor={feature.accent}>
            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0"
                style={`background: ${feature.accent}15; color: ${feature.accent}`}
              >
                <Fragment set:html={feature.icon} />
              </div>
              <div>
                <h3 class="text-lg font-semibold text-text-primary mb-1.5">{feature.title}</h3>
                <p class="text-text-secondary text-sm leading-relaxed">{feature.description}</p>
              </div>
            </div>
          </GlowCard>
        </div>
      ))}
    </div>
  </div>
</section>
