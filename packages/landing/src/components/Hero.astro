---
import GridPattern from "./ui/GridPattern.astro";
import GradientText from "./ui/GradientText.astro";
import Button from "./ui/Button.astro";
---

<section class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">
  <!-- Background effects -->
  <GridPattern />

  <!-- Glow orbs -->
  <div
    class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full opacity-15 blur-[120px] animate-float pointer-events-none"
    style="background: radial-gradient(circle, var(--color-accent-cyan), transparent 70%)"
  >
  </div>
  <div
    class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] rounded-full opacity-10 blur-[100px] animate-float-delayed pointer-events-none"
    style="background: radial-gradient(circle, var(--color-accent-purple), transparent 70%)"
  >
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <!-- Badge -->
    <div data-animate class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border-glow bg-accent-cyan/[0.06] mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-accent-cyan animate-pulse"></span>
      <span class="text-xs font-medium text-accent-cyan">New: MiniMax M2.5 &amp; OpenRouter support</span>
    </div>

    <!-- Heading -->
    <h1 data-animate data-animate-delay="1" class="text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.1] mb-6">
      Ship faster with<br />
      <GradientText>AI coding agents</GradientText>
    </h1>

    <!-- Subheadline -->
    <p data-animate data-animate-delay="2" class="text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
      Create tasks, generate specs, and let autonomous AI agents code your features.
      Monitor progress in real-time and approve PRs — all from one dashboard.
    </p>

    <!-- Buttons -->
    <div data-animate data-animate-delay="3" class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
      <Button href="#cta" variant="primary">Get Started</Button>
      <Button href="https://github.com/ezeoli88/dash-agent" variant="ghost">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
        </svg>
        View on GitHub
      </Button>
    </div>

    <!-- CLI snippet -->
    <div data-animate data-animate-delay="4" class="inline-flex items-center gap-3 px-5 py-3 rounded-lg bg-bg-surface border border-border-subtle font-mono text-sm">
      <span class="text-text-muted select-none">$</span>
      <span class="text-accent-cyan">npx</span>
      <span class="text-text-primary">ai-agent-board</span>
      <button
        class="text-text-muted hover:text-text-primary transition-colors ml-2"
        onclick="navigator.clipboard.writeText('npx ai-agent-board')"
        aria-label="Copy command"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
      </button>
    </div>
  </div>
</section>
