---
import Button from "./ui/Button.astro";
---

<nav class="fixed top-0 left-0 right-0 z-50 h-16 backdrop-blur-xl bg-bg-base/70 border-b border-border-subtle">
  <div class="max-w-6xl mx-auto h-full px-4 sm:px-6 flex items-center justify-between">
    <!-- Logo -->
    <a href={import.meta.env.BASE_URL} class="flex items-center gap-2.5">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent-cyan to-accent-blue flex items-center justify-center">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="16 18 22 12 16 6"></polyline>
          <polyline points="8 6 2 12 8 18"></polyline>
        </svg>
      </div>
      <span class="font-bold text-lg text-text-primary">Agent Board</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#features" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Features</a>
      <a href="#how-it-works" class="text-sm text-text-secondary hover:text-text-primary transition-colors">How it Works</a>
      <Button href="#cta" variant="primary" class="!py-2 !px-4 !text-xs">Get Started</Button>
    </div>

    <!-- Mobile CTA -->
    <div class="md:hidden">
      <Button href="#cta" variant="primary" class="!py-2 !px-4 !text-xs">Get Started</Button>
    </div>
  </div>
</nav>
